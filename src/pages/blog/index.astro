---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog', ({ data }) => {
  // Filter out drafts in production
  return import.meta.env.PROD ? !data.draft : true;
});

// Sort by date, newest first
const posts = allPosts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const formatDate = (date: Date) => {
  return date.toLocaleDateString('en-GB', {
    year: 'numeric',
    month: 'short',
    day: 'numeric',
  });
};
---

<BaseLayout title="Blog" description="Thoughts and writings">
  <div class="content-container">
    <div class="text-content">
      <h1>Blog</h1>
      <p>Thoughts on tech, health, and whatever else I find interesting.</p>

      {posts.length === 0 ? (
        <p class="no-posts">No posts yet. Check back soon!</p>
      ) : (
        <ul class="post-list">
          {posts.map((post) => (
            <li class="post-item">
              <a href={`/blog/${post.id}`} class="post-link">
                <span class="post-title">{post.data.title}</span>
                <span class="post-date">{formatDate(post.data.date)}</span>
              </a>
              {post.data.description && (
                <p class="post-description">{post.data.description}</p>
              )}
            </li>
          ))}
        </ul>
      )}
    </div>
  </div>
</BaseLayout>

<style>
  .post-list {
    list-style: none;
    padding: 0;
    margin: 2rem 0 0 0;
  }

  .post-item {
    margin-bottom: 1.5rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--border-color);
  }

  .post-item:last-child {
    border-bottom: none;
    margin-bottom: 0;
    padding-bottom: 0;
  }

  .post-link {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
    text-decoration: none;
  }

  .post-title {
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--accent-primary);
    min-width: 0;
  }

  .post-link:hover .post-title {
    text-decoration: underline;
  }

  .post-date {
    font-size: 0.875rem;
    color: var(--text-secondary);
    font-family: 'Source Code Pro', monospace;
    white-space: nowrap;
  }

  .post-description {
    margin: 0.5rem 0 0 0;
    color: var(--text-secondary);
    font-size: 0.95rem;
  }

  .no-posts {
    color: var(--text-secondary);
    font-style: italic;
  }
</style>
